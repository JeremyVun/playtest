{
  "name": "@jeremyvun/playtest",
  "version": "0.1.0",
  "description": "User journey testing for web apps: an AI agent role-plays a user against your app and the harness scores whether the app let it succeed.",
  "type": "module",
  "bin": {
    "playtest": "./src/harness/cli.js"
  },
  "files": [
    "src/harness",
    "src/shared",
    "src/todo-app",
    "src/demo",
    "src/viewer",
    "src/schemas",
    "personas",
    "skills",
    "docs/CONTRACTS.md",
    "docs/playtest-design.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "todo-app": "node src/todo-app/server.js",
    "mock-llm": "node src/harness/testing/mock-llm.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "playwright": "^1.53.0",
    "yaml": "^2.7.0"
  }
}
